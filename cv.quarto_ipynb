    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "markdown_output = \"\"\n",
        "\n",
        "for tcourse in data['courses']:\n",
        "    #foo = f\"\\\\footnotesize {tcourse['title']}, {tcourse['institution']} \\hfill {tcourse['term']}  \\n\"\n",
        "    foo = text_size_text + f\"{tcourse['title']}, {tcourse['institution']} \\\\hfill {tcourse['term']}  \\n\"\n",
