    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Read YAML file\n",
        "with open(\"data/mentoring.yaml\", \"r\") as file:\n",
        "    data = yaml.safe_load(file)\n",
        "\n",
        "# Select elements"
