@article{marchani_contrasting_2009,
	title = {Contrasting identity-by-descent estimators, association studies, and linkage analyses using the Framingham Heart Study data},
	volume = {3},
	issn = {1753-6561},
	url = {https://bmcproc.biomedcentral.com/articles/10.1186/1753-6561-3-S7-S102},
	doi = {10.1186/1753-6561-3-S7-S102},
	abstract = {We explored the utility of population- and pedigree-based analyses using the Framingham Heart Study genome-wide 50 k single-nucleotide polymorphism marker data provided for Genetic Analysis Workshop 16. Our aims were: 1) to compare identity-by-descent sharing estimates from variable amounts of data; 2) to apply each of these estimates to a case-control association study designed to control for relatedness among samples; and 3) to contrast these results to those obtained using model-based and model-free linkage analysis methods.},
	pages = {S102},
	issue = {S7},
	journaltitle = {{BMC} Proceedings},
	shortjournal = {{BMC} Proc},
	author = {Marchani, Elizabeth E and Di, Yanming and Choi, Yoonha and Cheung, Charles and Su, Ming and Boehm, Frederick and Thompson, Elizabeth A and Wijsman, Ellen M},
	urldate = {2024-01-07},
	date = {2009-12},
	langid = {english},
	keywords = {/unread},
	file = {Marchani et al. - 2009 - Contrasting identity-by-descent estimators, associ.pdf:/home/fred/Zotero/storage/G2FCTZSW/Marchani et al. - 2009 - Contrasting identity-by-descent estimators, associ.pdf:application/pdf},
}
